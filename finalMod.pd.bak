	<object type="DiagramSettings" id="570">
	    <field name="diagramId">
		<object type="DiagramId" id="571">
		    <field name="stringId">Scenarios</field>
		</object>
	    </field>
	    <field name="entitySettings"><list>
		<object type="DiagramEntitySetting" id="572">
		    <field name="entity">
			<object type="Scenario" id="573">
			    <base type="Entity">
				<field name="name">ComprarProductos scenario</field>
				<field name="uniqueId">16</field>
			    </base>

			    <field name="scope">:optional</field>
			    <field name="steps"><list>
				<object type="Step" id="574">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=18&gt;</field>
					<field name="description">Se comparte la lista de productos que van a ser comprados</field>
					<field name="uniqueId">18</field>
				    </base>

				    <field name="step">
					<object ref="63"/>
				    </field>
				</object>

				<object type="Step" id="575">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=20&gt;</field>
					<field name="description">Pregunta donde enviar la compra</field>
					<field name="uniqueId">20</field>
				    </base>

				    <field name="step">
					<object ref="64"/>
				    </field>
				</object>

				<object type="Step" id="576">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=22&gt;</field>
					<field name="description">Facilita el metodo de pago, ubicacion y prioridad</field>
					<field name="uniqueId">22</field>
				    </base>

				    <field name="step">
					<object ref="65"/>
				    </field>
				</object>

				<object type="Step" id="577">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=29&gt;</field>
					<field name="description">Busca transportista para una compra</field>
					<field name="uniqueId">29</field>
				    </base>

				    <field name="step">
					<object type="Scenario" id="578">
					    <base type="Entity">
						<field name="name">ProponerEntregaATransportista scenario</field>
						<field name="uniqueId">27</field>
					    </base>

					    <field name="scope">:optional</field>
					    <field name="steps"><list>
						<object type="Step" id="579">
						    <base type="Entity">
