	<object type="DiagramSettings" id="789">
	    <field name="diagramId">
		<object type="DiagramId" id="790">
		    <field name="stringId">Scenarios</field>
		</object>
	    </field>
	    <field name="entitySettings"><list>
		<object type="DiagramEntitySetting" id="791">
		    <field name="entity">
			<object type="Scenario" id="792">
			    <base type="Entity">
				<field name="name">ComprarProductos scenario</field>
				<field name="description">Flujo central del sistema. El asistente comunica la lista de productos a comprar. La tienda solicita datos de envio y pago, verifica stock, coordina la logistica (subescenario de transporte), cobra al usuario mediante el proveedor de pagos y finalmente emite el ticket de compra.</field>
				<field name="uniqueId">16</field>
			    </base>

			    <field name="scope">:optional</field>
			    <field name="context"></field>
			    <field name="steps"><list>
				<object type="Step" id="793">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=18&gt;</field>
					<field name="description">Se comparte la lista de productos que van a ser comprados</field>
					<field name="uniqueId">18</field>
				    </base>

				    <field name="step">
					<object ref="28"/>
				    </field>
				</object>

				<object type="Step" id="794">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=446&gt;</field>
					<field name="description">Se obtiene la informacion de direccion, prioridad y metodo de pago para la compra.</field>
					<field name="uniqueId">446</field>
				    </base>

				    <field name="step">
					<object ref="200"/>
				    </field>
				</object>

				<object type="Step" id="795">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=20&gt;</field>
					<field name="description">Pregunta donde enviar la compra</field>
					<field name="uniqueId">20</field>
				    </base>

				    <field name="step">
					<object ref="203"/>
				    </field>
				</object>

				<object type="Step" id="796">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=22&gt;</field>
					<field name="description">Facilita el metodo de pago, ubicacion y prioridad</field>
					<field name="uniqueId">22</field>
				    </base>

				    <field name="step">
					<object ref="202"/>
				    </field>
				</object>

				<object type="Step" id="797">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=459&gt;</field>
					<field name="description">Se prepara el pedido con los datos de compra proporcionados.</field>
					<field name="uniqueId">459</field>
				    </base>

				    <field name="step">
					<object ref="201"/>
				    </field>
				</object>

				<object type="Step" id="798">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=449&gt;</field>
					<field name="description">Se guarda el historial de compra del usuario para futuras recomendaciones.</field>
					<field name="uniqueId">449</field>
				    </base>

				    <field name="step">
					<object ref="198"/>
				    </field>
				</object>

				<object type="Step" id="799">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=31&gt;</field>
					<field name="description">Tienda envia toda la factura al asistente</field>
					<field name="uniqueId">31</field>
				    </base>

				    <field name="step">
					<object ref="204"/>
				    </field>
				</object>

				<object type="Step" id="800">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=448&gt;</field>
					<field name="description">Se cobra al usuario a traves del proveedor de pagos con el metodo de pago especificado.</field>
					<field name="uniqueId">448</field>
				    </base>

				    <field name="step">
					<object ref="163"/>
				    </field>
				</object>

				<object type="Step" id="801">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=452&gt;</field>
					<field name="description">Se realiza una transaccion ya sea cobro o pago con el proveedor de pagos.</field>
					<field name="uniqueId">452</field>
				    </base>

				    <field name="step">
					<object ref="171"/>
				    </field>
				</object>

				<object type="Step" id="802">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=392&gt;</field>
					<field name="description">Se confirma la transaccion con el proveedor de pagos
</field>
					<field name="uniqueId">392</field>
				    </base>

				    <field name="step">
					<object ref="168"/>
				    </field>
				</object>

				<object type="Step" id="803">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=447&gt;</field>
					<field name="description">Se informa al asistente de los datos de envio, la fecha estimada y el transportista elegido.</field>
					<field name="uniqueId">447</field>
				    </base>

				    <field name="step">
					<object ref="197"/>
				    </field>
				</object>

				<object type="Step" id="804">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=455&gt;</field>
					<field name="description">Subescenario interno de gestion de envio para coordinar la logistica y transporte.</field>
					<field name="uniqueId">455</field>
				    </base>

				</object>

				<object type="Step" id="805">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=454&gt;</field>
					<field name="description">Subescenario externo de gestion de envio manejado por el vendedor externo.</field>
					<field name="uniqueId">454</field>
				    </base>

				</object>

				<object type="Step" id="806">
				    <base type="Entity">
					<field name="name">&lt;Prometheus unique entity name au.edu.rmit.cs.prometheus.datamodel.jacob.Step ID=453&gt;</field>
					<field name="description">Se confirma el envio por parte del transporte o vendedor externo.</field>
					<field name="uniqueId">453</field>
				    </base>

				</object>

				<object type="Step" id="807">
				    <base type="Entity">
