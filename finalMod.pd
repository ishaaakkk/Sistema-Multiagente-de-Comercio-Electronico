			    <base type="Entity">
				<field name="name">PedirProductos scenario</field>
				<field name="description">El asistente virtual envia una peticion de busqueda con restricciones (marca, precio, valoracion, etc.). El sistema consulta el catalogo, aplica los filtros y devuelve una lista de productos al asistente.</field>
