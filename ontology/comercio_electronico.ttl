:fechaOperacion rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :OperacionPago ;
                rdfs:range xsd:dateTime ;
                rdfs:comment "Fecha y hora en la que se registra una operación económica" .


