:precioMinimo rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :RestriccionBusqueda ;
              rdfs:range xsd:decimal ;
              rdfs:comment "Precio mínimo indicado en una restricción de búsqueda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/precioOferta
:precioOferta rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :OfertaTransporte ;
              rdfs:range xsd:decimal ;
              rdfs:comment "Precio propuesto por un transportista para realizar un envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/precioProducto
:precioProducto rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Producto ;
                rdfs:range xsd:decimal ;
                rdfs:comment "Precio de venta de un producto" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/precioUnitario
:precioUnitario rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :LineaPedido ;
                rdfs:range xsd:decimal ;
                rdfs:comment "Precio de una unidad de producto dentro de una línea de pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/metodoPago
:metodoPago rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Pedido ;
            rdfs:range xsd:string ;
            rdfs:comment "Método de pago elegido por el cliente (tarjeta, paypal, transferencia, etc.)" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/dist
:dist rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:domain :Direccion ;
      rdfs:range xsd:integer ;
      rdfs:comment "Métrica logística unidimensional (0-1000) de proximidad operativa de la dirección de entrega" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/prioridadEntrega
:prioridadEntrega rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty ;
                  rdfs:domain :Pedido ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "Prioridad de entrega indicada para un pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/prioridadLote
:prioridadLote rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain :LoteEnvio ;
               rdfs:range xsd:integer ;
               rdfs:comment "Prioridad de entrega asignada a un lote de envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/puntosRecomendacion
:puntosRecomendacion rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Recomendacion ;
                     rdfs:range xsd:decimal ;
                     rdfs:comment "Puntuación calculada para ordenar o justificar una recomendación" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/puntuacion
:puntuacion rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Valoracion ;
            rdfs:range xsd:integer ;
            rdfs:comment "Valor numérico de una valoración de producto" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/referenciaPago
:referenciaPago rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :OperacionPago ;
                rdfs:range xsd:string ;
                rdfs:comment "Referencia externa asociada a una operación de pago" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/tipoBusqueda
:tipoBusqueda rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :BuscarProductos ;
              rdfs:range xsd:string ;
              rdfs:comment "Tipo de búsqueda solicitada al catálogo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/tipoEnvio
:tipoEnvio rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :LineaPedido ,
                       :Pedido ;
           rdfs:range xsd:string .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/valorTextoRestriccion
:valorTextoRestriccion rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf owl:topDataProperty ;
                       rdfs:domain :RestriccionBusqueda ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Valor textual usado en una restricción de búsqueda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/valoracionDePedido
:valoracionDePedido rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain :Valoracion ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Identificador del pedido completado al que corresponde una valoración" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/valoracionMedia
:valoracionMedia rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Producto ;
                 rdfs:range xsd:decimal ;
                 rdfs:comment "Valoración media acumulada de un producto" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/valoracionMinima
:valoracionMinima rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty ;
                  rdfs:domain :RestriccionBusqueda ;
                  rdfs:range xsd:decimal ;
                  rdfs:comment "Valoración mínima exigida en una restricción de búsqueda" .


###  http://www.semanticweb.org/ecsdi/directory/Address
<http://www.semanticweb.org/ecsdi/directory/Address> rdf:type owl:DatatypeProperty ;
                                                     rdfs:range xsd:string ;
                                                     rdfs:comment "Dirección HTTP anunciada por un agente en el servicio de directorio" .


###  http://www.semanticweb.org/ecsdi/directory/AgentType
<http://www.semanticweb.org/ecsdi/directory/AgentType> rdf:type owl:DatatypeProperty ;
                                                       rdfs:range xsd:string ;
                                                       rdfs:comment "Tipo funcional con el que un agente se registra o se busca en el servicio de directorio" .


###  http://www.semanticweb.org/ecsdi/directory/Name
<http://www.semanticweb.org/ecsdi/directory/Name> rdf:type owl:DatatypeProperty ;
                                                  rdfs:range xsd:string ;
                                                  rdfs:comment "Nombre identificador usado en el registro de un agente y en su entrada del servicio de directorio" .


###  http://www.semanticweb.org/ecsdi/directory/motivo
<http://www.semanticweb.org/ecsdi/directory/motivo> rdf:type owl:DatatypeProperty ;
                                                    rdfs:range xsd:string ;
                                                    rdfs:comment "Motivo textual asociado a una respuesta de fallo o rechazo del directorio" .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/ecsdi/comercio_electronico#MetodoDePago
:MetodoDePago rdf:type owl:Class ;
              rdfs:comment "Metodo de Pago proporcionado por el Asistente Virtual para realizar las compras o donde se le devuelve el importe al hacer una devolucion" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico#RespuestaDatosEnvio
:RespuestaDatosEnvio rdf:type owl:Class ;
                     rdfs:subClassOf :Respuesta .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Accion
:Accion rdf:type owl:Class ;
        rdfs:comment "Funcionalidad que un agente ejecuta a petición de otro mediante una request" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Actor
:Actor rdf:type owl:Class ;
       rdfs:subClassOf :AgenteExterno ;
       rdfs:comment "Representa los actores externos con los que interactúa la tienda, modelados con vocabulario propio del dominio" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/AgenteExterno
:AgenteExterno rdf:type owl:Class ;
               rdfs:comment "Agente software o entidad externa que interactúa con la tienda dentro de los protocolos del sistema" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/AsistenteVirtual
:AsistenteVirtual rdf:type owl:Class ;
                  rdfs:subClassOf :Actor ;
                  rdfs:comment "Representa el agente asistente del usuario, encargado de iniciar búsquedas, compras, devoluciones y recibir información de la tienda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/AvisarCL
:AvisarCL rdf:type owl:Class ;
          rdfs:subClassOf :Accion ;
          rdfs:comment "Acción mediante la cual el Agente Comerciante solicita a un Centro Logístico preparar o gestionar un pedido para envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/BuscarProductos
:BuscarProductos rdf:type owl:Class ;
                 rdfs:subClassOf :Accion ;
                 rdfs:comment "Acción mediante la cual el AsistenteVirtual solicita productos que cumplan un conjunto de restricciones de búsqueda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/CentroLogistico
:CentroLogistico rdf:type owl:Class ;
                 rdfs:comment "Centro interno de la tienda desde el que se preparan productos, se gestiona stock y se organizan lotes de envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/CobroCliente
:CobroCliente rdf:type owl:Class ;
              rdfs:subClassOf :OperacionPago ;
              owl:disjointWith :PagoVendedorExterno ,
                               :ReembolsoCliente ;
              rdfs:comment "Operación mediante la cual se cobra al AsistenteVirtual el importe de un pedido enviado. Disjunto con :ReembolsoCliente y :PagoVendedorExterno" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ComunicarProductosExternosPedidos
:ComunicarProductosExternosPedidos rdf:type owl:Class ;
                                   rdfs:subClassOf :Accion ;
                                   rdfs:comment "Acción mediante la cual el Agente Comerciante solicita a un vendedor externo que gestione los productos de un pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ConfirmacionCompra
:ConfirmacionCompra rdf:type owl:Class ;
                    rdfs:subClassOf :Respuesta ;
                    rdfs:comment "Respuesta que confirma la compra realizada correctamente, con el ticket de compra." .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ConfirmacionEnvio
:ConfirmacionEnvio rdf:type owl:Class ;
                   rdfs:subClassOf :Respuesta ;
                   rdfs:comment "Respuesta que confirma que un envío ha sido planificado o aceptado, indicando los datos necesarios para informar al usuario o continuar el proceso logístico" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ConfirmacionTransaccion
:ConfirmacionTransaccion rdf:type owl:Class ;
                         rdfs:subClassOf :Respuesta ;
                         rdfs:comment "Representa la confirmación de que una operación económica se ha completado correctamente" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/DarAltaProductoExterno
:DarAltaProductoExterno rdf:type owl:Class ;
                        rdfs:subClassOf :Accion ;
                        rdfs:comment "Acción mediante la cual un vendedor externo solicita añadir uno o más productos externos al catálogo de la tienda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/DecisionContratoTransporte
:DecisionContratoTransporte rdf:type owl:Class ;
                            rdfs:subClassOf :Respuesta ;
                            rdfs:comment "Cierre informativo de FIPA Contract Net entre el Centro Logístico y un Transportista. Lleva la oferta; la performativa accept-proposal o reject-proposal indica el resultado (cap. 7.3.2)" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Devolucion
:Devolucion rdf:type owl:Class ;
            rdfs:comment "Solicitud de retorno de un producto comprado, con motivo, resolución e información necesaria para gestionar la recogida y el reembolso" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Direccion
:Direccion rdf:type owl:Class ;
           rdfs:comment "Representa la dirección de entrega o recogida usada en pedidos, envíos y devoluciones" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/EnviarOpinion
:EnviarOpinion rdf:type owl:Class ;
               rdfs:subClassOf :Notificacion ;
               rdfs:comment "Comunicación informativa mediante la cual el AsistenteVirtual comparte una valoración de un producto comprado" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Envio
:Envio rdf:type owl:Class ;
       rdfs:comment "Representa un proceso de entrega o recogida asociado a un pedido, lote o devolución" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/EnvioDevolucion
:EnvioDevolucion rdf:type owl:Class ;
                 rdfs:subClassOf :Envio ;
                 owl:disjointWith :EnvioExterno ,
                                  :EnvioInterno ;
                 rdfs:comment "Representa un envío para recoger un producto devuelto por el cliente. Disjunto con :EnvioInterno y :EnvioExterno" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/EnvioExterno
:EnvioExterno rdf:type owl:Class ;
              rdfs:subClassOf :Envio ;
              owl:disjointWith :EnvioInterno ;
              rdfs:comment "Representa un envío gestionado directamente por un vendedor externo. Disjunto con :EnvioInterno y :EnvioDevolucion" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/EnvioInterno
:EnvioInterno rdf:type owl:Class ;
              rdfs:subClassOf :Envio ;
              rdfs:comment "Representa un envío gestionado por la tienda desde un centro logístico propio. Disjunto con :EnvioExterno y :EnvioDevolucion" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Factura
:Factura rdf:type owl:Class ;
         rdfs:comment "Documento asociado a un pedido que recoge el importe total y la información económica de la compra" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/LineaPedido
:LineaPedido rdf:type owl:Class ;
             rdfs:comment "Representa una unidad del pedido que vincula un producto concreto con una cantidad y un precio unitario" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/LoteEnvio
:LoteEnvio rdf:type owl:Class ;
           rdfs:comment "Agrupación de productos o líneas de pedido con destino y prioridad compatibles para ser enviados por un transportista" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Notificacion
:Notificacion rdf:type owl:Class ;
              rdfs:comment "Comunicación informativa entre agentes que comparte conocimiento o eventos, sin solicitar una funcionalidad externa al receptor" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/NotificarBusquedaRealizada
:NotificarBusquedaRealizada rdf:type owl:Class ;
                            rdfs:subClassOf :Notificacion ;
                            rdfs:comment "Protocolo Consulta Catálogo: notificación informativa que el Agente Catálogo envía al Agente Feedback tras procesar una BuscarProductos. Lleva el AsistenteVirtual originador, las restricciones aplicadas y los productos devueltos, para alimentar el historial de búsquedas usado por el algoritmo de recomendación (cap. 9)" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/NotificarCompraCompletada
:NotificarCompraCompletada rdf:type owl:Class ;
                           rdfs:subClassOf :Notificacion ;
                           rdfs:comment "Notificación mediante la cual el Agente Comerciante informa al Agente Feedback de que un pedido ha sido completado" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/OfertaTransporte
:OfertaTransporte rdf:type owl:Class ;
                  rdfs:comment "Propuesta realizada por un transportista para entregar un lote, indicando precio, fecha estimada y condiciones de entrega" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/OperacionPago
:OperacionPago rdf:type owl:Class ;
               rdfs:comment "Representa una operación económica solicitada al proveedor de pagos" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/PagarProductoExterno
:PagarProductoExterno rdf:type owl:Class ;
                      rdfs:subClassOf :SolicitarOperacionPago ;
                      rdfs:comment "Acción mediante la cual el Agente Comerciante solicita transferir al vendedor externo el importe de sus productos vendidos" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/PagoVendedorExterno
:PagoVendedorExterno rdf:type owl:Class ;
                     rdfs:subClassOf :OperacionPago ;
                     owl:disjointWith :ReembolsoCliente ;
                     rdfs:comment "Operación mediante la cual la tienda transfiere al vendedor externo el importe correspondiente a sus productos vendidos. Disjunto con :CobroCliente y :ReembolsoCliente" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Pedido
:Pedido rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :pedidoTieneLinea ;
                          owl:minCardinality "1"^^xsd:nonNegativeInteger
                        ] ;
        rdfs:comment "Representa una orden de compra hecha por el asistente virtual. Restricción DL: debe tener al menos una :pedidoTieneLinea (un pedido vacío no es válido)." .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/PedirFeedback
:PedirFeedback rdf:type owl:Class ;
               rdfs:subClassOf :Accion ;
               rdfs:comment "Acción mediante la cual el sistema solicita al AsistenteVirtual una valoración sobre un producto recibido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/PeticionInfoPedidoCompletado
:PeticionInfoPedidoCompletado rdf:type owl:Class ;
                              rdfs:subClassOf :Accion ;
                              rdfs:comment "Acción mediante la cual el Agente Devolución solicita al Agente Comerciante los datos de un pedido completado" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Producto
:Producto rdf:type owl:Class ;
          rdfs:comment "Representa un producto disponible en el catálogo de la tienda, con información necesaria para búsqueda, compra, envío, valoración y recomendación" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ProductoExterno
:ProductoExterno rdf:type owl:Class ;
                 rdfs:subClassOf :Producto ;
                 owl:disjointWith :ProductoInterno ;
                 rdfs:comment "Representa un producto anunciado por un vendedor externo. Puede ser enviado por la tienda o por el propio vendedor externo. Disjunto con :ProductoInterno" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ProductoInterno
:ProductoInterno rdf:type owl:Class ;
                 rdfs:subClassOf :Producto ;
                 rdfs:comment "Representa un producto gestionado directamente por la tienda y disponible en uno o varios centros logísticos propios. Disjunto con :ProductoExterno" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ProveedorPagos
:ProveedorPagos rdf:type owl:Class ;
                rdfs:subClassOf :Actor ;
                rdfs:comment "Representa la entidad externa encargada de ejecutar operaciones económicas como cobros, transferencias y reembolsos" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RealizarPedido
:RealizarPedido rdf:type owl:Class ;
                rdfs:subClassOf :Accion ;
                rdfs:comment "Acción mediante la cual se solicita la compra de uno o más productos, indicando líneas de pedido, dirección, prioridad de entrega y datos de pago" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Recomendacion
:Recomendacion rdf:type owl:Class ;
               rdfs:comment "Sugerencia de productos generada a partir del historial de compras, búsquedas y valoraciones" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ReembolsoCliente
:ReembolsoCliente rdf:type owl:Class ;
                  rdfs:subClassOf :OperacionPago ;
                  rdfs:comment "Operación mediante la cual se devuelve al AsistenteVirtual el importe de un producto cuya devolución ha sido aceptada" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RegistrarValoracion
:RegistrarValoracion rdf:type owl:Class ;
                     rdfs:subClassOf :Notificacion ;
                     rdfs:comment "Comunicación informativa heredada para representar la llegada de una valoración que el sistema integra en su conocimiento" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ResolucionDevolucion
:ResolucionDevolucion rdf:type owl:Class ;
                      rdfs:subClassOf :Respuesta ;
                      rdfs:comment "Representa la decisión tomada sobre una solicitud de devolución, indicando si ha sido aceptada o rechazada" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Respuesta
:Respuesta rdf:type owl:Class ;
           rdfs:comment "Representa las respuestas generadas por los agentes después de procesar una acción o petición" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RespuestaFeedback
:RespuestaFeedback rdf:type owl:Class ;
                   rdfs:subClassOf :Respuesta ;
                   rdfs:comment "Representa la respuesta del feedback del usuario" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RespuestaInfoPedidoCompletado
:RespuestaInfoPedidoCompletado rdf:type owl:Class ;
                               rdfs:subClassOf :Respuesta ;
                               rdfs:comment "Respuesta del Agente Comerciante con el grafo de un pedido completado para validar una devolución" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RestriccionBusqueda
:RestriccionBusqueda rdf:type owl:Class ;
                     rdfs:comment "Representa un criterio de filtrado aplicado sobre el catálogo de productos" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RestriccionMarca
:RestriccionMarca rdf:type owl:Class ;
                  rdfs:subClassOf :RestriccionBusqueda ;
                  rdfs:comment "Restricción que filtra productos por la marca indicada" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RestriccionNombre
:RestriccionNombre rdf:type owl:Class ;
                   rdfs:subClassOf :RestriccionBusqueda ;
                   rdfs:comment "Restricción que filtra productos por nombre o texto asociado al producto" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RestriccionPrecio
:RestriccionPrecio rdf:type owl:Class ;
                   rdfs:subClassOf :RestriccionBusqueda ;
                   rdfs:comment "Restricción que filtra productos según un precio mínimo, un precio máximo o ambos" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/RestriccionValoracion
:RestriccionValoracion rdf:type owl:Class ;
                       rdfs:subClassOf :RestriccionBusqueda ;
                       rdfs:comment "Restricción que filtra productos según su valoración mínima o media esperada" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ResultadoBusqueda
:ResultadoBusqueda rdf:type owl:Class ;
                   rdfs:subClassOf :Respuesta ;
                   rdfs:comment "Respuesta que contiene los productos que cumplen las restricciones indicadas en una búsqueda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/SolicitarCobro
:SolicitarCobro rdf:type owl:Class ;
                rdfs:subClassOf :SolicitarOperacionPago ;
                rdfs:comment "Acción mediante la cual el Agente Comerciante solicita cobrar al usuario el importe de un pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/SolicitarDevolucion
:SolicitarDevolucion rdf:type owl:Class ;
                     rdfs:subClassOf :Accion ;
                     rdfs:comment "Acción mediante la cual el AsistenteVirtual solicita devolver un producto comprado, indicando pedido, producto y motivo de devolución" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/SolicitarOperacionPago
:SolicitarOperacionPago rdf:type owl:Class ;
                        rdfs:subClassOf :Accion ;
                        rdfs:comment "Acción mediante la cual se solicita al proveedor de pagos ejecutar una operación económica asociada a una compra, devolución o pago a un vendedor externo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/SolicitarPresupuestoTransporte
:SolicitarPresupuestoTransporte rdf:type owl:Class ;
                                rdfs:subClassOf :Accion ;
                                rdfs:comment "Acción mediante la cual un centro logístico solicita ofertas a transportistas para entregar un lote de productos" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/SolicitarRecogidaDevolucion
:SolicitarRecogidaDevolucion rdf:type owl:Class ;
                             rdfs:subClassOf :Accion ;
                             rdfs:comment "Acción mediante la cual se solicita a un transportista o servicio de mensajería recoger un producto devuelto y enviarlo de vuelta a la tienda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/SolicitarReembolso
:SolicitarReembolso rdf:type owl:Class ;
                    rdfs:subClassOf :SolicitarOperacionPago ;
                    rdfs:comment "Acción mediante la cual el Agente Devolución solicita reembolsar al usuario una devolución aceptada" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/StockProducto
:StockProducto rdf:type owl:Class ;
               rdfs:comment "Representa la disponibilidad de un producto concreto en un centro logístico determinado" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Transportista
:Transportista rdf:type owl:Class ;
               rdfs:subClassOf :Actor ;
               rdfs:comment "Representa una empresa de transporte que recibe propuestas de envío y responde con ofertas" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/Valoracion
:Valoracion rdf:type owl:Class ;
            rdfs:comment "Opinión emitida sobre un producto recibido, usada para mejorar la información del catálogo y las recomendaciones" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/VendedorExterno
:VendedorExterno rdf:type owl:Class ;
                 rdfs:subClassOf :Actor ;
                 rdfs:comment "Representa una empresa externa que anuncia productos en la tienda y puede gestionar el envío de sus propios productos" .


###  http://www.semanticweb.org/ecsdi/directory/AgenteDirectorio
<http://www.semanticweb.org/ecsdi/directory/AgenteDirectorio> rdf:type owl:Class ;
                                                              rdfs:comment "Agente registrado en el servicio de directorio, con nombre, dirección, tipo funcional y capacidades opcionales" .


###  http://www.semanticweb.org/ecsdi/directory/BuscarAgente
<http://www.semanticweb.org/ecsdi/directory/BuscarAgente> rdf:type owl:Class ;
                                                          rdfs:subClassOf :Accion ;
                                                          rdfs:comment "Acción mediante la cual un agente solicita al directorio un agente de un tipo funcional concreto" .


###  http://www.semanticweb.org/ecsdi/directory/BuscarTodosAgentes
<http://www.semanticweb.org/ecsdi/directory/BuscarTodosAgentes> rdf:type owl:Class ;
                                                                rdfs:subClassOf :Accion ;
                                                                rdfs:comment "Acción mediante la cual un agente solicita al directorio todos los agentes registrados de un tipo funcional concreto" .


###  http://www.semanticweb.org/ecsdi/directory/EliminarAgente
<http://www.semanticweb.org/ecsdi/directory/EliminarAgente> rdf:type owl:Class ;
                                                            rdfs:subClassOf :Accion ;
                                                            rdfs:comment "Acción mediante la cual un agente solicita ser eliminado del registro del servicio de directorio" .


###  http://www.semanticweb.org/ecsdi/directory/RegistrarAgente
<http://www.semanticweb.org/ecsdi/directory/RegistrarAgente> rdf:type owl:Class ;
                                                             rdfs:subClassOf :Accion ;
                                                             rdfs:comment "Acción mediante la cual un agente solicita al servicio de directorio quedar registrado con su URI, nombre, dirección y tipo" .


###  http://www.semanticweb.org/ecsdi/directory/RespuestaBusqueda
<http://www.semanticweb.org/ecsdi/directory/RespuestaBusqueda> rdf:type owl:Class ;
                                                               rdfs:subClassOf <http://www.semanticweb.org/ecsdi/directory/RespuestaDirectorio> ;
                                                               rdfs:comment "Respuesta del directorio que contiene la URI, dirección y tipo de un agente encontrado" .


###  http://www.semanticweb.org/ecsdi/directory/RespuestaBusquedaMultiple
<http://www.semanticweb.org/ecsdi/directory/RespuestaBusquedaMultiple> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <http://www.semanticweb.org/ecsdi/directory/RespuestaDirectorio> ;
                                                                       rdfs:comment "Respuesta del directorio que agrupa varios resultados de búsqueda de agentes" .


###  http://www.semanticweb.org/ecsdi/directory/RespuestaDirectorio
<http://www.semanticweb.org/ecsdi/directory/RespuestaDirectorio> rdf:type owl:Class ;
                                                                 rdfs:subClassOf :Respuesta ;
                                                                 rdfs:comment "Respuesta emitida por el servicio de directorio ante acciones de registro, búsqueda o eliminación" .


