@prefix : <http://www.semanticweb.org/ecsdi/comercio_electronico/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://www.semanticweb.org/ecsdi/comercio_electronico/> .

<http://www.semanticweb.org/ecsdi/comercio_electronico> rdf:type owl:Ontology ;
                                                         dcterms:creator "Grupo ECSDI 2025/2026 2Q" ;
                                                         dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
                                                         dcterms:modified "2026-05-25"^^xsd:date ;
                                                         rdfs:comment "Ontología del sistema multiagente de comercio electrónico. Define los conceptos compartidos por los agentes para representar productos, ofertas, pedidos, pagos, envíos, devoluciones, valoraciones y recomendaciones. El dominio se modela con vocabulario propio para evitar dependencias innecesarias de ontologías externas; se mantiene time para instantes temporales." ;
                                                         rdfs:label "Ontologia de comercio electronico" ;
                                                         owl:versionInfo "1.1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/ecsdi/comercio_electronico#metodoPagoDeAsistente
:metodoPagoDeAsistente rdf:type owl:ObjectProperty ;
                       rdfs:domain :AsistenteVirtual ;
                       rdfs:range :MetodoDePago .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionSobreLote
:accionSobreLote rdf:type owl:ObjectProperty ;
                 rdfs:domain :Accion ;
                 rdfs:range :LoteEnvio ;
                 rdfs:comment "Relación que indica el lote de envío sobre el que actúa una acción logística" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionSobreOferta
:accionSobreOferta rdf:type owl:ObjectProperty ;
                   rdfs:domain :Accion ;
                   rdfs:range :OfertaTransporte ;
                   rdfs:comment "Relación que indica la oferta de transporte sobre la que actúa una acción" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionSobrePedido
:accionSobrePedido rdf:type owl:ObjectProperty ;
                   rdfs:domain :Accion ;
                   rdfs:range :Pedido ;
                   rdfs:comment "Relación que indica el pedido sobre el que se aplica una acción" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionSobreProducto
:accionSobreProducto rdf:type owl:ObjectProperty ;
                     rdfs:domain :Accion ;
                     rdfs:range :Producto ;
                     rdfs:comment "Relación que indica el producto sobre el que se aplica una acción" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionSolicitadaPor
:accionSolicitadaPor rdf:type owl:ObjectProperty ;
                     rdfs:domain :Accion ;
                     rdfs:range :Actor ;
                     rdfs:comment "Actor que solicita la ejecución de una acción" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionTieneOperacionPago
:accionTieneOperacionPago rdf:type owl:ObjectProperty ;
                          rdfs:domain :SolicitarOperacionPago ;
                          rdfs:range :OperacionPago ;
                          rdfs:comment "Relación que vincula una acción de pago con la operación económica que debe ejecutarse" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionTieneRestriccion
:accionTieneRestriccion rdf:type owl:ObjectProperty ;
                        rdfs:domain :BuscarProductos ;
                        rdfs:range :RestriccionBusqueda ;
                        rdfs:comment "Relación que asocia una búsqueda de productos con las restricciones usadas para filtrar el catálogo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/accionTieneValoracion
:accionTieneValoracion rdf:type owl:ObjectProperty ;
                       owl:equivalentProperty :notificacionTieneValoracion ;
                       rdfs:domain :Notificacion ;
                       rdfs:range :Valoracion ;
                       rdfs:comment "DEPRECATED: usar :notificacionTieneValoracion. Se mantiene como propiedad equivalente para retrocompatibilidad con grafos existentes" ;
                       owl:deprecated "true"^^xsd:boolean .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/confirmacionDeOperacion
:confirmacionDeOperacion rdf:type owl:ObjectProperty ;
                         rdfs:domain :ConfirmacionTransaccion ;
                         rdfs:range :OperacionPago ;
                         rdfs:comment "Relación que indica la operación de pago confirmada por una respuesta de transacción" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/confirmacionEnvio
:confirmacionEnvio rdf:type owl:ObjectProperty ;
                   rdfs:domain :ConfirmacionEnvio ;
                   rdfs:range :Envio ;
                   rdfs:comment "Relación que vincula una confirmación de envío con el envío confirmado" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/devolucionDePedido
:devolucionDePedido rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Devolucion ;
                    rdfs:range :Pedido ;
                    rdfs:comment "Relación que indica el pedido al que pertenece una devolución (functional: cada devolución es de un único pedido)" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/devolucionDeProducto
:devolucionDeProducto rdf:type owl:ObjectProperty ;
                      rdfs:domain :Devolucion ;
                      rdfs:range :Producto ;
                      rdfs:comment "Relación que indica el producto concreto solicitado para devolución" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/devolucionTieneReembolso
:devolucionTieneReembolso rdf:type owl:ObjectProperty ;
                          rdfs:domain :Devolucion ;
                          rdfs:range :ReembolsoCliente ;
                          rdfs:comment "Relación que vincula una devolución aceptada con la operación de reembolso correspondiente" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/envioDePedido
:envioDePedido rdf:type owl:ObjectProperty ;
               owl:inverseOf :pedidoTieneEnvio ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain :Envio ;
               rdfs:range :Pedido ;
               rdfs:comment "Relación que indica el pedido asociado a un envío. Inversa de :pedidoTieneEnvio" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/envioDesdeCentro
:envioDesdeCentro rdf:type owl:ObjectProperty ;
                  rdfs:domain :EnvioInterno ;
                  rdfs:range :CentroLogistico ;
                  rdfs:comment "Centro logístico origen de un envío interno. Necesario para la extensión avanzada multi-CL: el asistente recibe varias confirmaciones, una por cada centro implicado" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/envioDestinoDir
:envioDestinoDir rdf:type owl:ObjectProperty ;
                 rdfs:domain :Accion ;
                 rdfs:range :Direccion ;
                 rdfs:comment "Relación que indica la dirección de destino comunicada en una acción de envío externo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/envioExternoGestionadoPor
:envioExternoGestionadoPor rdf:type owl:ObjectProperty ;
                           rdfs:domain :EnvioExterno ;
                           rdfs:range :VendedorExterno ;
                           rdfs:comment "Relación que indica el vendedor externo responsable de gestionar un envío externo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/envioRealizadoPor
:envioRealizadoPor rdf:type owl:ObjectProperty ;
                   rdfs:domain :Envio ;
                   rdfs:range :Transportista ;
                   rdfs:comment "Relación que indica el transportista asignado para realizar un envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/envioTieneLote
:envioTieneLote rdf:type owl:ObjectProperty ;
                rdfs:domain :EnvioInterno ;
                rdfs:range :LoteEnvio ;
                rdfs:comment "Relación que vincula un envío interno con el lote de productos transportado" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/facturaDePedido
:facturaDePedido rdf:type owl:ObjectProperty ;
                 owl:inverseOf :pedidoTieneFactura ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain :Factura ;
                 rdfs:range :Pedido ;
                 rdfs:comment "Relación que indica el pedido al que corresponde una factura. Inversa de :pedidoTieneFactura" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/lineaDeProducto
:lineaDeProducto rdf:type owl:ObjectProperty ;
                 rdfs:domain :LineaPedido ;
                 rdfs:range :Producto ;
                 rdfs:comment "Relación que indica el producto incluido en una línea de pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/loteDestinoDireccion
:loteDestinoDireccion rdf:type owl:ObjectProperty ;
                      rdfs:domain :LoteEnvio ;
                      rdfs:range :Direccion ;
                      rdfs:comment "Relación que indica la dirección de destino de un lote de envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/loteGestionadoPorCentro
:loteGestionadoPorCentro rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty ;
                         rdfs:domain :LoteEnvio ;
                         rdfs:range :CentroLogistico ;
                         rdfs:comment "Relacion que muestra que centro logistico se encarga de un lote" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/loteOrigenCentro
:loteOrigenCentro rdf:type owl:ObjectProperty ;
                  rdfs:domain :LoteEnvio ;
                  rdfs:range :CentroLogistico ;
                  rdfs:comment "Relación que indica el centro logístico desde el que se prepara un lote de envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/loteTieneLinea
:loteTieneLinea rdf:type owl:ObjectProperty ;
                rdfs:domain :LoteEnvio ;
                rdfs:range :LineaPedido ;
                rdfs:comment "Relación que indica las líneas de pedido incluidas en un lote de envío" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/notificacionSobrePedido
:notificacionSobrePedido rdf:type owl:ObjectProperty ;
                         rdfs:domain :Notificacion ;
                         rdfs:range :Pedido ;
                         rdfs:comment "Relación que indica el pedido sobre el que informa una notificación" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/notificacionSobreProducto
:notificacionSobreProducto rdf:type owl:ObjectProperty ;
                           rdfs:domain :Notificacion ;
                           rdfs:range :Producto ;
                           rdfs:comment "Relación que indica el producto sobre el que informa una notificación" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/notificacionTieneValoracion
:notificacionTieneValoracion rdf:type owl:ObjectProperty ;
                             rdfs:domain :Notificacion ;
                             rdfs:range :Valoracion ;
                             rdfs:comment "Relación que vincula una notificación informativa con una valoración emitida" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ofertaParaLote
:ofertaParaLote rdf:type owl:ObjectProperty ;
                rdfs:domain :OfertaTransporte ;
                rdfs:range :LoteEnvio ;
                rdfs:comment "Relación que indica el lote de envío para el que se realiza una oferta de transporte" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ofertaRealizadaPor
:ofertaRealizadaPor rdf:type owl:ObjectProperty ;
                    rdfs:domain :OfertaTransporte ;
                    rdfs:range :Transportista ;
                    rdfs:comment "Relación que indica el transportista que realiza una oferta de transporte" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoDeUsuario
:pedidoDeUsuario rdf:type owl:ObjectProperty ;
                 owl:equivalentProperty :pedidoSolicitadoPor ;
                 rdfs:domain :Pedido ;
                 rdfs:range :AsistenteVirtual ;
                 rdfs:comment "DEPRECATED: usar :pedidoSolicitadoPor. Se mantiene como propiedad equivalente para retrocompatibilidad" ;
                 owl:deprecated "true"^^xsd:boolean .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoEnviadoA
:pedidoEnviadoA rdf:type owl:ObjectProperty ;
                rdfs:domain :Pedido ;
                rdfs:range :Direccion ;
                rdfs:comment "Relación que indica la dirección de entrega de un pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoSolicitadoPor
:pedidoSolicitadoPor rdf:type owl:ObjectProperty ;
                     rdfs:domain :Pedido ;
                     rdfs:range :AsistenteVirtual .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoTieneConfirmacion
:pedidoTieneConfirmacion rdf:type owl:ObjectProperty ;
                         rdfs:domain :Pedido ;
                         rdfs:range :ConfirmacionEnvio ;
                         rdfs:comment "Relación que vincula un pedido con la confirmación de envío recibida" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoTieneEnvio
:pedidoTieneEnvio rdf:type owl:ObjectProperty ;
                  rdfs:domain :Pedido ;
                  rdfs:range :Envio ;
                  rdfs:comment "Relación que vincula un pedido con un envío asociado, interno o externo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoTieneFactura
:pedidoTieneFactura rdf:type owl:ObjectProperty ;
                    rdfs:domain :Pedido ;
                    rdfs:range :Factura ;
                    rdfs:comment "Relación que indica el AsistenteVirtual que solicita un pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoTieneLinea
:pedidoTieneLinea rdf:type owl:ObjectProperty ;
                  rdfs:domain :Pedido ;
                  rdfs:range :LineaPedido ;
                  rdfs:comment "Relación que vincula un pedido con las líneas de pedido que lo componen" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/pedidoTieneOperacionPago
:pedidoTieneOperacionPago rdf:type owl:ObjectProperty ;
                          rdfs:domain :Pedido ;
                          rdfs:range :OperacionPago ;
                          rdfs:comment "Relación que vincula un pedido con la operación económica asociada" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/productoOfrecidoPor
:productoOfrecidoPor rdf:type owl:ObjectProperty ;
                     rdfs:domain :ProductoExterno ;
                     rdfs:range :VendedorExterno ;
                     rdfs:comment "Relación que indica el vendedor externo que ofrece un producto externo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/recomendacionDeProducto
:recomendacionDeProducto rdf:type owl:ObjectProperty ;
                         rdfs:domain :Recomendacion ;
                         rdfs:range :Producto ;
                         rdfs:comment "Relación que indica el producto sugerido en una recomendación" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/recomendacionParaAsistente
:recomendacionParaAsistente rdf:type owl:ObjectProperty ;
                            rdfs:domain :Recomendacion ;
                            rdfs:range :AsistenteVirtual ;
                            rdfs:comment "Relación que indica el AsistenteVirtual destinatario de una recomendación" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/resolucionDeDevolucion
:resolucionDeDevolucion rdf:type owl:ObjectProperty ;
                        rdfs:domain :ResolucionDevolucion ;
                        rdfs:range :Devolucion ;
                        rdfs:comment "Relación que vincula una resolución con la devolución que resuelve" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/respuestaDeAccion
:respuestaDeAccion rdf:type owl:ObjectProperty ;
                   rdfs:domain :Respuesta ;
                   rdfs:range :Accion ;
                   rdfs:comment "Relación que indica la acción a la que responde una respuesta del sistema" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/respuestaSobreOferta
:respuestaSobreOferta rdf:type owl:ObjectProperty ;
                      rdfs:domain :Respuesta ;
                      rdfs:range :OfertaTransporte ;
                      rdfs:comment "Relación que indica la oferta de transporte sobre la que informa una respuesta" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/respuestaSobrePedido
:respuestaSobrePedido rdf:type owl:ObjectProperty ;
                      rdfs:domain :Respuesta ;
                      rdfs:range :Pedido ;
                      rdfs:comment "Relación que indica el pedido sobre el que informa una respuesta" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/resultadoContieneProducto
:resultadoContieneProducto rdf:type owl:ObjectProperty ;
                           rdfs:domain :ResultadoBusqueda ;
                           rdfs:range :Producto ;
                           rdfs:comment "Relación que indica los productos incluidos en un resultado de búsqueda" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/stockDeProducto
:stockDeProducto rdf:type owl:ObjectProperty ;
                 rdfs:domain :StockProducto ;
                 rdfs:range :Producto ;
                 rdfs:comment "Relación que indica el producto al que corresponde una entrada de stock" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/stockEnCentro
:stockEnCentro rdf:type owl:ObjectProperty ;
               rdfs:domain :StockProducto ;
               rdfs:range :CentroLogistico ;
               rdfs:comment "Relación que indica el centro logístico donde se encuentra una entrada de stock" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/valoracionDeProducto
:valoracionDeProducto rdf:type owl:ObjectProperty ;
                      rdfs:domain :Valoracion ;
                      rdfs:range :Producto ;
                      rdfs:comment "Relación que indica el producto valorado en una valoración" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/valoracionEnviadaPor
:valoracionEnviadaPor rdf:type owl:ObjectProperty ;
                      rdfs:domain :Valoracion ;
                      rdfs:range :AsistenteVirtual ;
                      rdfs:comment "Relación que indica el AsistenteVirtual que envía una valoración" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/vendedorDestinatario
:vendedorDestinatario rdf:type owl:ObjectProperty ;
                      rdfs:domain :PagarProductoExterno ;
                      rdfs:range :VendedorExterno ;
                      rdfs:comment "Relación que indica el vendedor externo destinatario de un pago" .


###  http://www.semanticweb.org/ecsdi/directory/Capability
<http://www.semanticweb.org/ecsdi/directory/Capability> rdf:type owl:ObjectProperty ;
                                                        rdfs:comment "Capacidad funcional declarada o solicitada en el directorio; su valor es una URI de acción o servicio de la ontología compartida" .


###  http://www.semanticweb.org/ecsdi/directory/Uri
<http://www.semanticweb.org/ecsdi/directory/Uri> rdf:type owl:ObjectProperty ;
                                                 rdfs:range <http://www.semanticweb.org/ecsdi/directory/AgenteDirectorio> ;
                                                 rdfs:comment "URI del agente registrado o devuelto por el servicio de directorio" .


###  http://www.semanticweb.org/ecsdi/directory/respuestaDeAccion
<http://www.semanticweb.org/ecsdi/directory/respuestaDeAccion> rdf:type owl:ObjectProperty ;
                                                               rdfs:domain <http://www.semanticweb.org/ecsdi/directory/RespuestaDirectorio> ;
                                                               rdfs:range :Accion ;
                                                               rdfs:comment "Acción de directorio a la que responde una confirmación, fallo o resultado" .


###  http://www.semanticweb.org/ecsdi/directory/resultadoContiene
<http://www.semanticweb.org/ecsdi/directory/resultadoContiene> rdf:type owl:ObjectProperty ;
                                                               rdfs:domain <http://www.semanticweb.org/ecsdi/directory/RespuestaBusquedaMultiple> ;
                                                               rdfs:range <http://www.semanticweb.org/ecsdi/directory/RespuestaBusqueda> ;
                                                               rdfs:comment "Relación entre una respuesta múltiple del directorio y cada resultado de búsqueda individual" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/ecsdi/comercio_electronico#tarjeta
:tarjeta rdf:type owl:DatatypeProperty ;
         rdfs:domain :MetodoDePago ,
                     :RespuestaDatosEnvio ;
         rdfs:range xsd:string .


###  http://www.semanticweb.org/ecsdi/comercio_electronico#urgencia
:urgencia rdf:type owl:DatatypeProperty ;
          rdfs:domain :RespuestaDatosEnvio ;
          rdfs:range xsd:string .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/calle
:calle rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Direccion ;
       rdfs:range xsd:string ;
       rdfs:comment "Nombre de la calle de una dirección de entrega o recogida" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/cantidad
:cantidad rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:domain :LineaPedido ;
          rdfs:range xsd:integer ;
          rdfs:comment "Número de unidades de un producto dentro de una línea de pedido" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/cantidadDisponible
:cantidadDisponible rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain :StockProducto ;
                    rdfs:range xsd:integer ;
                    rdfs:comment "Cantidad disponible de un producto en un centro logístico" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ciudad
:ciudad rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:domain :Direccion ;
        rdfs:range xsd:string ;
        rdfs:comment "Ciudad asociada a una dirección" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/ciudadCentroLogistico
:ciudadCentroLogistico rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf owl:topDataProperty ;
                       rdfs:domain :CentroLogistico ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Ciudad donde se encuentra un centro logístico" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/codigoPostal
:codigoPostal rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Direccion ;
              rdfs:range xsd:string ;
              rdfs:comment "Código postal asociado a una dirección" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/comentario
:comentario rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Valoracion ;
            rdfs:range xsd:string ;
            rdfs:comment "Texto libre incluido en una valoración de producto" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/descripcionProducto
:descripcionProducto rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Producto ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Descripción textual de un producto del catálogo" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/devolucionAceptada
:devolucionAceptada rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain :Devolucion ;
                    rdfs:range xsd:boolean ;
                    rdfs:comment "Indica si una solicitud de devolución ha sido aceptada o rechazada" .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/dist
:dist rdf:type owl:DatatypeProperty ;
      rdfs:domain :RespuestaDatosEnvio ,
                  :CentroLogistico ;
      rdfs:range xsd:unsignedInt .


###  http://www.semanticweb.org/ecsdi/comercio_electronico/estadoLote
